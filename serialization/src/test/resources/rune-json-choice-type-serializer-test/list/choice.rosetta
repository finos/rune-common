namespace serialization.test.passing.list

annotation rootType: <"Mark a type as a root of the rosetta model">

type A:
  fieldA string (1..1)

type B:
  fieldB string (1..1)

choice ChoiceData:
  A
  B

type EconomicTerms:
  payout ChoiceData (0..*)

type Product:
  economicTerms EconomicTerms (1..1)

type Root:
  [rootType]
  product Product (1..1)
